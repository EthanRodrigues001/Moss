# Public Supabase project URL used by the Next.js frontend.
NEXT_PUBLIC_SUPABASE_URL=https://vqlvkprydgfswknybnvd.supabase.co

# Public Supabase anon/publishable key used by the browser client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Rust compiler backend URL. Local default is http://localhost:8787.
NEXT_PUBLIC_COMPILER_API_URL=

# Rust compiler backend

# HTTP port for the Axum compiler service.
PORT=8787

# Allowed frontend origin for browser compile requests.
CORS_ORIGIN=http://localhost:3000

# Max JSON upload payload size accepted by the compiler backend.
MAX_UPLOAD_MB=80

# Per-compile timeout in milliseconds.
COMPILE_TIMEOUT_MS=60000

# Compiler mode: auto, latexmk, or tectonic.
# auto tries latexmk first for PDFLaTeX, then falls back to Tectonic if latexmk is missing.
# latexmk forces latexmk and fails clearly if latexmk is not installed.
# tectonic forces Tectonic.
MOSS_COMPILER_ENGINE=auto

# latexmk executable name or absolute path.
LATEXMK_BIN=latexmk

# Optional semicolon-separated paths prepended when running compiler commands.
# Windows local example:
# COMPILER_EXTRA_PATH=C:\Strawberry\perl\bin;C:\Strawberry\c\bin;C:\Users\YourName\AppData\Local\Programs\MiKTeX\miktex\bin\x64
COMPILER_EXTRA_PATH=

# Tectonic executable name or absolute path.
TECTONIC_BIN=tectonic

# SyncTeX executable name or absolute path for PDF click-to-source lookup.
SYNCTEX_BIN=synctex

# Enable XeLaTeX when your host image actually has XeLaTeX support.
ENABLE_XELATEX=false

# Enable LuaLaTeX when your host image actually has LuaLaTeX support.
ENABLE_LUALATEX=false

# Tectonic package cache directory.
TECTONIC_CACHE_DIR=.tectonic-cache

# Directory for short-lived per-compile source workspaces.
COMPILE_WORK_DIR=.compile-tmp

# Directory for short-lived PDF/SyncTeX artifacts used by preview source jumps.
COMPILE_ARTIFACT_DIR=

# How long compile artifacts are kept for SyncTeX reverse lookup.
COMPILE_ARTIFACT_TTL_MS=600000
